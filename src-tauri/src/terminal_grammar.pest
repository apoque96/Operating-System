WHITESPACE = _{ " " }

number = @{ ASCII_DIGIT+ }

char = { ASCII_ALPHANUMERIC | "." | "_" | "/" }

string = @{ char+ }

help = { "help" }

params = @{ "-" ~ string }

command = { "ls" | "pwd" | "mkdir" ~ string| "cd" ~ string | "rm" ~ string | "touch" ~ string | "mv" ~ string ~ string | "ps" | "run" | "kill" | "mem" | help}

pipe = { "|" }

line = { SOI ~ (command ~ (pipe ~ command)*)* ~ EOI }